// Recovery state machine. Render: dot -Tpng recovery_state_machine.dot -o recovery_state_machine.png
digraph recovery {
  rankdir=TB;
  node [shape=box, style="rounded,filled", fillcolor="#eef6ff", fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=10];

  IDLE; MONITORING; CONFIRMING; STOPPING; RECOVERING; VERIFYING; RESUMING; COOLDOWN;
  FAULT [fillcolor="#ffe8e8"]; ESTOP [fillcolor="#ffd0d0"];

  IDLE        -> MONITORING  [label="arm"];
  MONITORING  -> CONFIRMING  [label="entangled\n(conf >= min)"];
  CONFIRMING  -> MONITORING  [label="cleared\n(false alarm)"];
  CONFIRMING  -> STOPPING    [label="sustained >= confirmation_time\n[locomotion]  / cmd: StopMove"];
  CONFIRMING  -> RECOVERING  [label="sustained & already stopped\n(skip StopMove)"];
  STOPPING    -> RECOVERING  [label="StopMove ok &\n(not locomotion | settle)\ncmd: BalanceStand*"];
  RECOVERING  -> VERIFYING   [label="Stand ok &\n(upright | settle)"];
  VERIFYING   -> RESUMING    [label="detector clear\n>= verification_duration"];
  VERIFYING   -> RECOVERING  [label="still entangled\n> verify_timeout (re-attempt)"];
  RESUMING    -> COOLDOWN    [label="resume_delay elapsed\n(hand control back)"];
  COOLDOWN    -> MONITORING  [label="cooldown elapsed"];

  // escalation + safety
  RECOVERING  -> RECOVERING  [label="* fall detected ->\nRecoveryStand"];
  STOPPING    -> FAULT       [label="retries exhausted"];
  RECOVERING  -> FAULT       [label="retries exhausted"];
  VERIFYING   -> FAULT       [label="re-attempts exhausted"];
  CONFIRMING  -> FAULT       [label="watchdog", style=dashed];
  FAULT       -> IDLE        [label="reset / auto_reset\n(cmd: Damp on entry)"];

  // global e-stop (from any state)
  MONITORING  -> ESTOP [style=dotted, color=red, label="estop"];
  STOPPING    -> ESTOP [style=dotted, color=red];
  RECOVERING  -> ESTOP [style=dotted, color=red];
  VERIFYING   -> ESTOP [style=dotted, color=red];
  ESTOP       -> IDLE  [label="reset (cmd: Damp on entry)"];
}
