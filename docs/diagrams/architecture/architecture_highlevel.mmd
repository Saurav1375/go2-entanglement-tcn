    C["<b>Multi-task causal TCN</b><br/>shared encoder + 3 heads<br/>fixed split 16/4/5 + LORO-CV"]
    D["<b>Artifacts</b><br/>model.pt<br/>normalize / intensity / calibration.json"]
    A --> B --> C --> D
  end

  E["<b>Export → ONNX + calib JSON</b><br/>deployed runtime ≡ research (≈1e-6)"]
  D --> E

  %% ---------------- ONLINE ----------------
  subgraph ONLINE["ONLINE · on-robot deployment (ROS 2, CPU-only)"]
    direction LR
    R(["<b>Unitree GO2</b><br/>Sport service · sensors + actuators"])
    DET["<b>Detector node</b><br/>ring buffer (200) · TCN (ONNX)<br/>calibrate · debounce · stationarity gate"]
    REC["<b>Recovery node</b><br/>FSM (10 states) · StrategyManager<br/>closed-loop ladder · dry-run gate"]
    OP["<b>Operator</b> / logs"]
    R -->|"/lowstate ~500 Hz"| DET
    DET -->|"/entanglement_state"| REC
    REC -->|"/recovery_status"| OP
    REC -->|"/api/sport/request (dry-run gated) → motion → new proprioception"| R
  end

